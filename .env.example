# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: curated | mock | ollama | claude
#
# curated: No API key needed. Deterministic, source-bound Socratic questions
#          for the reviewed case catalogue. Works offline. Default.
#
# mock  : No API key needed. Rule-based demo provider for development and tests.
#
# ollama: Free local LLM. Requires Ollama running locally:
#           brew install ollama
#           ollama pull llama3.2
#           ollama serve
#         Then set OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# claude: Anthropic claude-opus-4-7 with extended thinking. Best quality.
#         Requires ANTHROPIC_API_KEY.
LLM_PROVIDER=curated

# Anthropic API key (only needed when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# Ollama config (only needed when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2
# PROVIDER_READINESS_TIMEOUT_SECONDS=10
# PROVIDER_READINESS_CACHE_SECONDS=300

# ─── App ──────────────────────────────────────────────────────────────────────
# APP_ENV=development
# SECRET_KEY=change-me-in-production
# ADMIN_BOOTSTRAP_TOKEN=set-a-one-time-random-token-before-first-admin-setup
#
# Production checklist:
# - Set APP_ENV=production
# - Set SECRET_KEY to a long random value
# - Set DATABASE_AUTO_CREATE_TABLES=false and run Alembic migrations
# - Set CORS_ORIGINS to your real frontend origin
# - Choose LLM_PROVIDER=curated, ollama, or claude intentionally
