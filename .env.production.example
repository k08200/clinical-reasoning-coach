# Copy to .env.production and replace every placeholder before deployment.
APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_AUTO_CREATE_TABLES=false
ADMIN_BOOTSTRAP_TOKEN=replace-with-a-one-time-random-bootstrap-token
# Bump this identifier whenever the educational-use statement changes.
EDUCATIONAL_USE_CONSENT_VERSION=2026-07-15
REVIEWER_CREDENTIAL_VALID_DAYS=365
# Production learner release requires independent approval by at least two current clinician reviewers.
CLINICAL_REVIEW_MINIMUM_DISTINCT_REVIEWERS=2
RATE_LIMIT_ENABLED=true
# Add the egress IP address(es) of a reverse proxy only when it forwards
# X-Forwarded-For. Keep this empty when the backend receives client traffic directly.
TRUSTED_PROXY_IPS=[]
AUTH_REGISTRATION_RATE_LIMIT_PER_HOUR=12
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=12
AUTH_REFRESH_RATE_LIMIT_PER_MINUTE=60
CASE_GENERATION_RATE_LIMIT_PER_HOUR=12
DEMO_CASE_RATE_LIMIT_PER_HOUR=60
COACHING_STREAM_RATE_LIMIT_PER_HOUR=120

POSTGRES_USER=clinical_coach
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=clinical_coach

# This must be the browser-visible HTTPS URL for the API, not an internal Docker hostname.
NEXT_PUBLIC_API_URL=https://api.example.com
FRONTEND_PORT=3000
CORS_ORIGINS=["https://app.example.com"]

# Use mock only for non-clinical demonstrations. Choose an intentionally configured provider for deployment.
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
# Required production attestation for the exact provider/model evaluated by clinical reviewers.
MODEL_RELEASE_APPROVAL_ID=replace-with-versioned-clinical-model-evaluation-id
MODEL_RELEASE_APPROVAL_PROVIDER=claude
MODEL_RELEASE_APPROVAL_MODEL=claude-opus-4-7
MODEL_RELEASE_APPROVAL_EXPIRES_ON=2026-10-15
# Run scripts/run-model-release-evaluation.py against this exact provider/model,
# retain its JSON artifact for clinician review, and copy its printed SHA-256 here.
MODEL_RELEASE_EVALUATION_SHA256=replace-with-evaluation-artifact-sha256
MODEL_RELEASE_EVALUATION_ARTIFACT_PATH=/app/model-release-evaluation.json
# Absolute host path to the same reviewed JSON artifact; Docker mounts it read-only.
MODEL_RELEASE_EVALUATION_ARTIFACT_HOST_PATH=/absolute/path/model-release-evaluation.json
# Required only when LLM_PROVIDER=ollama. The model must report this context size or larger.
OLLAMA_MIN_CONTEXT_TOKENS=4096
PROVIDER_READINESS_TIMEOUT_SECONDS=10
PROVIDER_READINESS_CACHE_SECONDS=300
