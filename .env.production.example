# Copy to .env.production and replace every placeholder before deployment.
APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_AUTO_CREATE_TABLES=false
ADMIN_BOOTSTRAP_TOKEN=replace-with-a-one-time-random-bootstrap-token
# Bump this identifier whenever the educational-use statement changes.
EDUCATIONAL_USE_CONSENT_VERSION=2026-07-15
REVIEWER_CREDENTIAL_VALID_DAYS=365

POSTGRES_USER=clinical_coach
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=clinical_coach

# This must be the browser-visible HTTPS URL for the API, not an internal Docker hostname.
NEXT_PUBLIC_API_URL=https://api.example.com
FRONTEND_PORT=3000
CORS_ORIGINS=["https://app.example.com"]

# Use mock only for non-clinical demonstrations. Choose an intentionally configured provider for deployment.
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
PROVIDER_READINESS_TIMEOUT_SECONDS=10
PROVIDER_READINESS_CACHE_SECONDS=300
